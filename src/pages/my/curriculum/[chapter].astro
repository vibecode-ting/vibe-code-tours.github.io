---
import Base from '../../../layouts/Base.astro';
import ChapterDetailBody from '../../../components/ChapterDetailBody.astro';
import { chapters } from '../../../data/chapters';
import { t } from '../../../i18n/utils';

export function getStaticPaths() {
  return chapters.map((c) => ({ params: { chapter: `ch-${c.num}` } }));
}

const { chapter } = Astro.params;
const num = Number(String(chapter).replace('ch-', ''));
const ch = chapters.find((c) => c.num === num);
const s = t('my').curriculum;
const title = ch ? `Ch${num} — ${ch.title}` : s.title;
---
<Base title={title} description={ch?.outcome ?? s.description}>
  <ChapterDetailBody num={num} />
</Base>
