---
// Military-style rank insignia for chapter level (ch-0..ch-8).
// Tiers by metal: 0 steel · 1-3 silver (chevrons) · 4-6 gold+wings (stars) ·
// 7-8 amethyst+wings (stars). Pure SVG — scalable, themeable, no raster assets.
interface Props {
  level: number; // 0..8
  size?: number; // px, default 44
  title?: string;
}
const { level, size = 44, title } = Astro.props;
const lv = Math.max(0, Math.min(8, level));

// tier metals: gradient stops (bright/mid/edge/deep), inner panel, insignia ink
const TIERS = {
  steel: {
    hi: "#eef2f8",
    mid: "#8b95a4",
    edge: "#c2ccd9",
    deep: "#5c6675",
    panel: "#222b3a",
    ink: "#9aa4b3",
    rivet: "#d7dde6",
    wings: false,
  },
  silver: {
    hi: "#ffffff",
    mid: "#9fadbf",
    edge: "#d7e1ee",
    deep: "#6c7a8d",
    panel: "#1d2837",
    ink: "#e6eef9",
    rivet: "#f1f5fb",
    wings: false,
  },
  gold: {
    hi: "#fff3c4",
    mid: "#d4a428",
    edge: "#ffd968",
    deep: "#9a6e12",
    panel: "#173028",
    ink: "#fff0bd",
    rivet: "#ffe9ad",
    wings: true,
  },
  amethyst: {
    hi: "#f1e3ff",
    mid: "#8b4ff0",
    edge: "#c79bff",
    deep: "#5b27b5",
    panel: "#1f1338",
    ink: "#f0e2ff",
    rivet: "#ecdcff",
    wings: true,
  },
};
const tier =
  lv === 0
    ? TIERS.steel
    : lv <= 3
      ? TIERS.silver
      : lv <= 6
        ? TIERS.gold
        : TIERS.amethyst;

const chevrons = lv >= 1 && lv <= 3 ? lv : 0;
const stars = lv >= 4 ? (lv <= 6 ? lv - 3 : lv - 5) : 0; // 4-6 -> 1-3, 7-8 -> 2-3
const uid = `rb${lv}`;

function star(cx: number, cy: number, r: number) {
  const pts = [];
  for (let i = 0; i < 10; i++) {
    const ang = (Math.PI / 5) * i - Math.PI / 2;
    const rad = i % 2 === 0 ? r : r * 0.42;
    pts.push(
      `${(cx + rad * Math.cos(ang)).toFixed(1)},${(cy + rad * Math.sin(ang)).toFixed(1)}`,
    );
  }
  return "M" + pts.join("L") + "Z";
}
const starRow = (n: number, cy: number, r: number) => {
  const gap = r * 2.25;
  const x0 = 60 - ((n - 1) * gap) / 2;
  return Array.from({ length: n }, (_, i) => star(x0 + i * gap, cy, r));
};
const chevron = (i: number) => {
  const y = 49 + i * 13;
  return `M43 ${y} L60 ${y + 12} L77 ${y} L77 ${y + 7} L60 ${y + 19} L43 ${y + 7} Z`;
};
// rivet positions = shield vertices
const rivets = [
  [30, 25],
  [90, 25],
  [101, 64],
  [60, 106],
  [19, 64],
];
---

<svg
  width={size}
  height={size}
  viewBox="-10 4 140 122"
  role="img"
  aria-label={title ?? `Chapter ${lv} rank`}
  class="rank-badge"
  data-wings={tier.wings ? "" : undefined}
>
  {title && <title>{title}</title>}
  <defs>
    <linearGradient id={`${uid}f`} x1="0.2" y1="0" x2="0.8" y2="1">
      <stop offset="0" stop-color={tier.hi}></stop>
      <stop offset="0.42" stop-color={tier.mid}></stop>
      <stop offset="0.62" stop-color={tier.deep}></stop>
      <stop offset="1" stop-color={tier.edge}></stop>
    </linearGradient>
    <linearGradient id={`${uid}p`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color={tier.panel}></stop>
      <stop offset="1" stop-color="#080b12"></stop>
    </linearGradient>
    <linearGradient id={`${uid}w`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color={tier.hi}></stop>
      <stop offset="1" stop-color={tier.mid}></stop>
    </linearGradient>
    <radialGradient id={`${uid}r`} cx="0.35" cy="0.3" r="0.8">
      <stop offset="0" stop-color={tier.rivet}></stop>
      <stop offset="1" stop-color={tier.deep}></stop>
    </radialGradient>
    <clipPath id={`${uid}c`}>
      <path d="M30 25 L90 25 L101 64 L60 106 L19 64 Z"></path>
    </clipPath>
  </defs>

  {/* wings (gold/amethyst) — layered feathers, mirrored */}
  {
    tier.wings && (
      <g>
        <g
          id={`${uid}wing`}
          fill={`url(#${uid}w)`}
          stroke="#00000022"
          stroke-width="0.6"
        >
          <path d="M57 33 C82 19 103 17 121 21 C104 24 91 30 75 41 C69 37 63 35 57 36 Z" />
          <path
            d="M57 38 C78 26 96 25 111 29 C96 31 85 36 72 45 C67 41 62 39 57 40 Z"
            opacity="0.9"
          />
          <path
            d="M57 43 C73 33 88 33 100 37 C88 39 79 43 69 49 C65 46 61 44 57 44 Z"
            opacity="0.8"
          />
          <path
            d="M57 47 C69 41 81 41 90 45 C81 47 74 50 67 53 C64 51 60 49 57 49 Z"
            opacity="0.7"
          />
        </g>
        <use href={`#${uid}wing`} transform="matrix(-1 0 0 1 120 0)" />
      </g>
    )
  }

  {/* outer shield frame */}
  <path
    d="M30 25 L90 25 L101 64 L60 106 L19 64 Z"
    fill={`url(#${uid}f)`}
    stroke="#00000040"
    stroke-width="2"
    stroke-linejoin="round"></path>
  {/* bevel rim */}
  <path
    d="M35 30 L85 30 L94 63 L60 99 L26 63 Z"
    fill="none"
    stroke={tier.hi}
    stroke-opacity="0.5"
    stroke-width="1.2"
    stroke-linejoin="round"></path>
  {/* inner panel */}
  <path
    d="M38 33 L82 33 L92 64 L60 96 L28 64 Z"
    fill={`url(#${uid}p)`}
    stroke="#00000055"
    stroke-width="1"></path>

  {/* insignia */}
  <g fill={tier.ink} stroke="#00000033" stroke-width="0.5">
    {
      chevrons > 0 &&
        Array.from({ length: chevrons }, (_, i) => <path d={chevron(i)} />)
    }
    {
      stars > 0 &&
        starRow(stars, 64, 12).map((d) => <path d={d} class="rbstar" />)
    }
  </g>

  {/* rivets */}
  {
    rivets.map(([x, y]) => (
      <circle
        cx={x}
        cy={y}
        r="2.6"
        fill={`url(#${uid}r)`}
        stroke="#00000044"
        stroke-width="0.5"
      />
    ))
  }

  {/* animated shine sweep (clipped to shield) */}
  <g clip-path={`url(#${uid}c)`}>
    <g class="rbshine">
      <rect
        x="-30"
        y="-12"
        width="26"
        height="150"
        fill="#ffffff"
        opacity="0.5"
        transform="skewX(-18)"></rect>
    </g>
  </g>

  {/* top gloss */}
  <path d="M33 28 L87 28 L80 37 L40 37 Z" fill="#ffffff" opacity="0.22"></path>
</svg>

<style>
  .rank-badge {
    transition:
      transform 0.3s cubic-bezier(0.22, 0.61, 0.36, 1),
      filter 0.3s ease;
    transform-origin: center;
    will-change: transform;
  }
  /* Motion on intent only: a gentle lift + faint catch-light. No spin, no idle. */
  :global(.group:hover) .rank-badge,
  :global(.group:focus-within) .rank-badge {
    transform: scale(1.05) translateY(-1px);
    filter: drop-shadow(0 2px 5px rgba(0, 0, 0, 0.35));
  }
  .rbshine {
    transform: translateX(-60px);
    opacity: 0;
  }
  /* one restrained shine sweep, hover/focus only, fades in and out */
  :global(.group:hover) .rbshine,
  :global(.group:focus-within) .rbshine {
    animation: rbShine 1.15s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes rbShine {
    0% {
      transform: translateX(-55px);
      opacity: 0;
    }
    22% {
      opacity: 0.55;
    }
    100% {
      transform: translateX(172px);
      opacity: 0;
    }
  }
  .rbstar {
    transform-box: fill-box;
    transform-origin: center;
  }
  @media (prefers-reduced-motion: reduce) {
    .rank-badge {
      transition: none;
    }
    .rbshine {
      animation: none !important;
    }
  }
</style>
